# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=""

# DATABASE_URL: PostgreSQL connection string for Drizzle ORM (Supabase Postgres or custom Cloud SQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/guardiancam"

# Supabase Auth and Client Config
# Note for your provided keys:
# - NEXT_PUBLIC_SUPABASE_URL corresponds to your SUPABASE_URL (e.g., https://vbypsyvmeqnepaqkzwhc.supabase.co)
# - NEXT_PUBLIC_SUPABASE_ANON_KEY corresponds to your SUPABASE_PUBLISHABLE_KEY (e.g., sb_publishable_ErwvfmHdEi5O1saWB-Fd7w_siL5AauA)
# - SUPABASE_SERVICE_ROLE_KEY corresponds to your SUPABASE_SECRET_KEY
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWKS_URL="https://your-supabase-project.supabase.co/auth/v1/.well-known/jwks.json"
SUPABASE_PROJECT_ID="your-supabase-project-id"

# Stripe API Config
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

